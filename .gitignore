# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User settings
xcuserdata/

## compatibility with Xcode 8 and earlier (faulty Xcode crash log, etc)
*.xcscmblueprint
*.xccheckout

## generated by XcodeGen
*.xcodeproj
*.xcworkspace

## Xcode server
xcshareddata/WorkspaceSettings.xcsettings

### macOS ###
.DS_Store
.AppleDouble
.LSOverride

# Build and IDE
build/
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Swift Package Manager
.build/
Packages/
Package.pins
Package.resolved

# Crashlytics/Fabric
crashlytics-build.properties

# Dependency managers
Podfile.lock
Pods/
Carthage/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Temp files
*~
*.swp
*.tmp

# Local tooling archive
xcodegen.zip

# Release artifacts
Release/

# Cursor IDE (local only)
.cursor/
